rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read, write: if true;
    }

    match /stories/{storyId} {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }
  }
}
